# === SECURITY: Never commit these ===
/_backups/
/.env
/.env.backup
/.env.production.bak
/firebase-auth.json
*.pem
*.sql
app/logs/*.log

# === Deploy scripts (contain server paths) ===
/deploy.ps1
/deploy.bat

# === Laravel standard ignores ===
/node_modules
/public/hot
/public/storage
/public/store/*
/public/debug_paytabs.log

# === Compiled public assets (re-generated by npm/artisan) ===
/public/assets/
/public/vendor/
/public/mix-manifest.json

# === Large files exceeding GitHub 100MB limit ===
/database/regions/cities.json
!/public/store/.htaccess
/storage/*.key
/storage/framework/views
/storage/framework/laravel-excel
/vendor

# === IDE ===
/.idea
/.vscode

# === Build & cache ===
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
composer.lock
storage/debugbar/.gitignore

# === Misc ===
/build_output.txt
/.temp_backup_*
